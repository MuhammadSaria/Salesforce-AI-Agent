NODE_ENV=development
PORT=3000
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379
QUEUE_DRIVER=redis
MIDDLEWARE_API_TOKEN=replace-with-a-long-random-secret
ALLOWED_ORIGINS=
AI_PROVIDER=openai
AI_MODEL=gpt-5.5
OPENAI_ENABLED=false
OPENAI_API_KEY=
AGENT_BACKEND=openai
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_AGENT_ACCOUNT_ID=
JIRA_WEBHOOK_SECRET=
JIRA_ALLOWED_PROJECT_KEYS=SAPA
SALESFORCE_ORG_REGISTRY_PATH=./config/org-registry.json
SALESFORCE_PROJECT_ROOT=..
PROJECT_ROOT=..
WORKSPACE_ROOT=..
MAX_METADATA_COMPONENTS=100
MAX_RETRIEVED_COMPONENTS=100
MAX_DEPENDENCY_DEPTH=3
MAX_METADATA_SIZE_BYTES=5000000
MAX_RETRIEVAL_OPERATIONS=5
VALIDATION_EXPIRY_MINUTES=60
ALLOW_PRODUCTION_DEPLOYMENT=false
AUDIT_LOG_LEVEL=info
LOG_LEVEL=info
SF_COMMAND_TIMEOUT_MS=120000
SF_CLI_NODE=
SF_CLI_RUN=
MAX_PROMPT_LENGTH=8000
